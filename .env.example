# ----- Base de données -----
# URL Mongo (replica set requis pour Prisma).
DATABASE_URL="mongodb://user:password@localhost:27017/conge?replicaSet=rs0&authSource=admin"

# ----- Auth / JWT -----
# Secret HS256 — DOIT être généré aléatoirement (>= 32 octets) et tourné régulièrement.
# Exemple : `node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"`
JWT_SECRET="change-me-with-a-strong-random-secret"

# ----- Seeds (utilisé par scripts/seeds, JAMAIS comme mot de passe par défaut prod) -----
SEED_ADMIN_PASSWORD="ChooseAStrongSeedPassword!"

# ----- SMTP / emails -----
# Active l'envoi de mail. Si SMTP_HOST/SMTP_FROM absents, les emails sont désactivés silencieusement.
EMAIL_NOTIFICATIONS_ENABLED="true"
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="no-reply@example.com"
SMTP_PASS="change-me"
SMTP_FROM="\"Conge\" <no-reply@example.com>"

# ----- Logging -----
# Niveaux : trace | debug | info | warn | error | fatal
LOG_LEVEL="info"

# ----- Cron / tâches automatiques (optionnel) -----
# Secret partagé pour les endpoints /api/leave-requests/auto-approve-overdue
CRON_SECRET="change-me-cron-secret"

# ----- Next.js -----
NODE_ENV="development"
