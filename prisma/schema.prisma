/// Le schéma centralise les collections Mongo utilisées par l'app Veilleur des Médias :
/// employés, congés, documents RH, bulletins, départements et services.
/// Les sections suivantes détaillent les générateurs et la source de données.
/// Génère le client Prisma principal utilisé par l'app (répertoire généré/prisma).
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

/// Génère le client utilitaire présent dans node_modules pour que `prisma db push` fonctionne aussi.
generator nodeClient {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

/// Source MongoDB, l'URL est injectée via `.env`.
datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

/// Pour catégoriser les départements de l'entreprise.
enum DepartmentType {
  DAF
  DSI
  OPERATIONS
  OTHERS
}

/// Services spécialisés rattachés à la Direction des Opérations.
enum ServiceType {
  INFORMATION
  REPUTATION
  QUALITE
}

/// Rôle occupé par un.e responsable dans un département.
enum ResponsibilityRole {
  RESPONSABLE
  CO_RESPONSABLE
  ADJOINT
}

/// Rôles métiers utilisés dans les policies/contrôles d'accès.
enum EmployeeRole {
  CEO
  ACCOUNTANT
  DEPT_HEAD
  SERVICE_HEAD
  EMPLOYEE
}

enum NotificationCategory {
  INFO
  ALERT
  ACTION
}

/// Types de documents que l'on peut uploader pour un employé.
enum EmployeeDocumentType {
  ID_CARD
  DRIVING_LICENSE
  BIRTH_CERTIFICATE
  SPOUSE_BIRTH_CERTIFICATE
  CHILD_BIRTH_CERTIFICATE
  CURRICULUM_VITAE
  COVER_LETTER
  GEOGRAPHIC_LOCATION
  CONTRACT
}

/// Statut du dossier employé (private pending=nouveau, rejected=à corriger).
enum EmployeeStatus {
  PENDING
  ACTIVE
  REJECTED
}

/// Statut civil utile pour les attestations/congés exceptionnels.
enum MaritalStatus {
  SINGLE
  MARRIED
}

/// Pour les formulaires d'information employé.
enum EmployeeGender {
  FEMALE
  MALE
  OTHER
}

/// Étapes possibles d'une demande de congés.
enum LeaveStatus {
  SUBMITTED
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

/// Catégories de congés utilisées pour le calcul du solde.
enum LeaveType {
  ANNUAL_PAID
  ANTICIPATED_PAID
  ANNUAL
  FAMILY_EXCEPTIONAL
  MENSTRUAL
  CONGE_M
  MATERNITY_PATERNITY
  SICK
  SICKNESS
  UNPAID
  TRAINING
  OTHER
}

/// Actions enregistrées lors d'une décision ou d'un commentaire sur un congé.
enum DecisionType {
  SUBMIT
  APPROVE
  REJECT
  ESCALATE
  COMMENT
  CANCEL
}

model Department {
  /// Identifiant Mongo
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  /// Type unique pour éviter les doublons
  type        DepartmentType @unique
  /// Libellé humain
  name        String
  description String?

  members        Employee[]                 @relation("DepartmentMembers")
  responsables   DepartmentResponsibility[]
  services       Service[]
  leaveBlackouts LeaveBlackout[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  /// Relation vers `Department`
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  /// Type métier du service (Information/Reputation/Qualité)
  type        ServiceType
  /// Nom affiché dans l'UI
  name        String
  /// Texte descriptif rôle du service
  description String?

  departmentId String     @db.ObjectId
  department   Department @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  /// Membres liés à ce service
  members Employee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([departmentId, type])
  @@index([departmentId])
}

model Employee {
  /// Donnée personnelle / login
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  firstName String
  lastName  String
  email     String @unique

  /// Identifiant interne facultatif pour badges/matricules
  matricule         String? // PAS @unique (si tu as des null). Utilise un index unique partiel Mongo si besoin.
  /// Métier / fonction
  jobTitle          String?
  /// Coordonnées
  phone             String?
  profilePhotoUrl   String?
  fullAddress       String?
  /// Informations démographiques
  gender            EmployeeGender?
  maritalStatus     MaritalStatus?
  childrenCount     Int?
  /// Dates RH et numéro CNPS
  hireDate          DateTime?
  companyEntryDate  DateTime?
  hireDateFormatted String?
  cnpsNumber        String?
  password          String

  /// Rôle exploité dans les autorisations front/back
  role                   EmployeeRole   @default(EMPLOYEE)
  /// Statut : pending jusqu’à validation par administrateur
  status                 EmployeeStatus @default(PENDING)
  /// Solde de congés principal
  leaveBalance           Float          @default(26)
  /// Ajustements manuels apportés par le CEO/comptable
  leaveBalanceAdjustment Float          @default(0)
  /// Jours de congés déjà consommés avant déploiement (appliqués une seule année)
  firstYearLeaveUsedDays Float          @default(0)
  /// Année d'application de `firstYearLeaveUsedDays` (null = inactif)
  firstYearLeaveUsedYear Int?

  // Auto-relation (approbation) => NoAction obligatoire sur un côté
  approvedById   String?    @db.ObjectId
  approvedBy     Employee?  @relation("EmployeeApprovals", fields: [approvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approvalsGiven Employee[] @relation("EmployeeApprovals")

  departmentId String?     @db.ObjectId
  department   Department? @relation("DepartmentMembers", fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  serviceId String?  @db.ObjectId
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  responsibilities             DepartmentResponsibility[]
  supervisedResponsibilities   DepartmentResponsibility[] @relation("ResponsibilitySupervisor")
  salarySlips                  SalarySlip[]               @relation("SalarySlipOwner")
  uploadedSalarySlips          SalarySlip[]               @relation("SalarySlipUploader")
  signedSalarySlips            SalarySlip[]               @relation("SalarySlipSigner")
  documents                    EmployeeDocument[]         @relation("EmployeeDocuments")
  uploadedDocuments            EmployeeDocument[]         @relation("EmployeeDocumentUploader")
  createdContractDocumentTypes ContractDocumentType[]     @relation("EmployeeCreatedContractDocumentTypes")
  notifications                Notification[]             @relation("EmployeeNotifications")
  ceoSignatureImageDataUrl     String?
  ceoSignatureImageMimeType    String?

  // Congés
  leaveRequests          LeaveRequest[]  @relation("EmployeeLeaveRequests")
  assignedLeaves         LeaveRequest[]  @relation("LeaveAssignee")
  leaveDecisions         LeaveDecision[] @relation("LeaveActor")
  receivedLeaveDecisions LeaveDecision[] @relation("LeaveDecisionTo")
  createdBlackouts       LeaveBlackout[]
  createdHolidays        Holiday[]

  /// Indique qu'une réinitialisation de mot de passe a été demandée
  passwordResetRequested Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([status])
  @@index([departmentId])
  @@index([serviceId])
}

model Holiday {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  /// Date fériée (jour complet)
  date  DateTime
  label String?
  /// Si true, ce jour est férié chaque année (mois/jour pris depuis `date`).
  /// Stockage: on ancre la date sur une année "technique" (cf. lib/holidays.ts).
  isRecurring Boolean? @default(false)

  /// Créé par (comptable/DAF)
  createdById String?   @db.ObjectId
  createdBy   Employee? @relation(fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime @default(now())

  @@unique([date])
  @@index([createdById])
}

model Notification {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  title    String
  body     String
  category NotificationCategory @default(INFO)

  /// Notifications personnalisées
  employeeId String?   @db.ObjectId
  employee   Employee? @relation("EmployeeNotifications", fields: [employeeId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  /// Broadcasting ciblés
  targetRole EmployeeRole?
  global     Boolean       @default(false)

  /// Pour marquer la lecture côté destinataire
  isRead Boolean @default(false)

  metadata Json?

  createdAt DateTime @default(now())

  @@index([employeeId])
  @@index([targetRole])
  @@index([isRead])
  @@index([createdAt])
}

model SalarySlip {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  /// Propriétaire du bulletin
  employeeId String   @db.ObjectId
  employee   Employee @relation("SalarySlipOwner", fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  year  Int
  month Int

  fileName    String
  mimeType    String
  fileDataUrl String

  /// Employé qui a uploadé le fichier
  uploadedById           String    @db.ObjectId
  uploadedBy             Employee  @relation("SalarySlipUploader", fields: [uploadedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  /// Signature optionnelle (CEO, DAF)
  signedById             String?   @db.ObjectId
  signedBy               Employee? @relation("SalarySlipSigner", fields: [signedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  signedAt               DateTime?
  signatureImageDataUrl  String?
  signatureImageMimeType String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, year, month])
  @@index([employeeId])
  @@index([uploadedById])
  @@index([signedById])
  @@index([year, month])
}

model EmployeeDocument {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  /// Employé concerné
  employeeId String   @db.ObjectId
  employee   Employee @relation("EmployeeDocuments", fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  /// Type du document (CV, carte, etc.)
  type              EmployeeDocumentType
  relatedPersonName String?
  childOrder        Int?
  validUntil        DateTime?
  expirationNotificationSentAt DateTime?
  fileName          String
  mimeType          String
  fileDataUrl       String

  contractDocumentTypeId String?               @db.ObjectId
  contractDocumentType   ContractDocumentType? @relation("ContractDocumentTypeDocuments", fields: [contractDocumentTypeId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  /// Uploadé par ce collaborateur
  uploadedById String   @db.ObjectId
  uploadedBy   Employee @relation("EmployeeDocumentUploader", fields: [uploadedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([uploadedById])
  @@index([type])
  @@index([contractDocumentTypeId])
  @@index([createdAt])
}

model ContractDocumentType {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  /// Nom unique du type (ex : contrat CDI, avenant)
  name String @unique

  /// Créateur du type
  createdById String   @db.ObjectId
  createdBy   Employee @relation("EmployeeCreatedContractDocumentTypes", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  documents EmployeeDocument[] @relation("ContractDocumentTypeDocuments")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
}

model DepartmentResponsibility {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  /// Département concerné
  departmentId String     @db.ObjectId
  department   Department @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  /// Responsable lié
  employeeId String   @db.ObjectId
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  /// Superviseur éventuel de la responsabilité
  supervisorId String?   @db.ObjectId
  supervisor   Employee? @relation("ResponsibilitySupervisor", fields: [supervisorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  role    ResponsibilityRole @default(RESPONSABLE)
  startAt DateTime           @default(now())
  endAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([departmentId, employeeId, startAt])
  @@index([departmentId])
  @@index([employeeId])
  @@index([supervisorId])
}

model LeaveRequest {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  /// Demandeur
  employeeId String   @db.ObjectId
  employee   Employee @relation("EmployeeLeaveRequests", fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  /// Métadonnées du congé
  type      LeaveType
  startDate DateTime
  endDate   DateTime
  reason    String?
  justificationFileName    String?
  justificationMimeType    String?
  justificationFileDataUrl String?

  status LeaveStatus @default(SUBMITTED)

  /// Personne qui doit encore statuer
  currentAssigneeId String?   @db.ObjectId
  currentAssignee   Employee? @relation("LeaveAssignee", fields: [currentAssigneeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  /// Traces d'escalade
  deptHeadAssignedAt DateTime?
  reachedCeoAt       DateTime?

  decisions LeaveDecision[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([status])
  @@index([currentAssigneeId])
  @@index([employeeId, createdAt])
  @@index([employeeId, status, startDate, endDate])
  @@index([status, currentAssigneeId, createdAt])
}

model LeaveDecision {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  /// Demande liée
  leaveRequestId String       @db.ObjectId
  leaveRequest   LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  /// Acteur qui prend la décision
  actorId String   @db.ObjectId
  actor   Employee @relation("LeaveActor", fields: [actorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  type    DecisionType
  comment String?

  /// Si la décision est adressée à un.e autre personne
  toEmployeeId String?   @db.ObjectId
  toEmployee   Employee? @relation("LeaveDecisionTo", fields: [toEmployeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime @default(now())

  @@index([leaveRequestId])
  @@index([actorId])
  @@index([type])
  @@index([toEmployeeId])
  @@index([actorId, createdAt])
  @@index([type, createdAt])
  @@index([actorId, type, createdAt])
}

model LeaveBlackout {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  /// Blocage contextuel
  title     String?
  reason    String?
  startDate DateTime
  endDate   DateTime

  /// Optionnel : ciblage par département
  departmentId String?     @db.ObjectId
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  employeeIds  String[]    @default([]) @db.ObjectId

  /// Auteur de ce blackout
  createdById String   @db.ObjectId
  createdBy   Employee @relation(fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([departmentId])
  @@index([startDate])
  @@index([endDate])
}
